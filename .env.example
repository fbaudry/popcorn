XTREAM_BASE_URL=https://example.com:8080
XTREAM_USERNAME=username
XTREAM_PASSWORD=password
XTREAM_CONNECTION_NAME=My Xtream
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
FFPROBE_PATH=/opt/homebrew/bin/ffprobe
PLAYBACK_TEMP_DIR=/tmp/popcorn/playback
PLAYBACK_MAX_TRANSCODES=1
PLAYBACK_MAX_QUEUE_LENGTH=6
PLAYBACK_SESSION_TTL_SECONDS=900
PLAYBACK_TRANSCODE_PRESET=veryfast
